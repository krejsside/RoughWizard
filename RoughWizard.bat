@echo off
title @ RoughWizard
cls

:Menu
color 05
echo.
echo.
echo   Welcome to RoughWizard.
echo.
echo.
echo   1 apply all tweaks
echo.
echo   2 cleaner
echo.
echo.
set /p input=:
if /i %input% == 1 goto Optymalizacja
if /i %input% == 2 goto cleaner
) ELSE (
echo Invalid Input & goto MisspellRedirect

:MisspellRedirect
cls
echo Misspell Detected
timeout 2
goto RedirectMenu

@echo off
setlocal enabledelayedexpansion

REM Ustaw lokalną wersję
set "local=2.55"
set "localtwo=!local!"

REM Adres URL repozytorium GitHuba
set "repo_url=https://github.com/krejsside/RoughWizard/raw/main/"

REM Usuń plik tymczasowy, jeśli istnieje
if exist "%temp%\RoughWizard.bat" del /s /q /f "%temp%\RoughWizard.bat" >nul 2>&1

REM Pobierz najnowszą wersję pliku RoughWizard.bat
curl -g -L -# -o "%temp%\RoughWizard.bat" "%repo_url%RoughWizard.bat" >nul 2>&1

REM Sprawdź, czy dostępna jest nowa wersja
if exist "%temp%\RoughWizard.bat" (
    cls
    Mode 65,16
    echo.
    echo  --------------------------------------------------------------
    echo                           Update found
    echo  --------------------------------------------------------------
    echo.
    echo                    Your current version: %localtwo%
    echo.
    echo                          New version: %local%
    echo.
    echo.
    echo.
    echo      [Y] Yes, Update
    echo      [N] No
    echo.
    choice /c:YN /n /m "%DEL%                                >:"
    set choice=!errorlevel!
    if !choice! equ 1 (
        REM Zastąp lokalną kopię najnowszą wersją
        move /y "%temp%\RoughWizard.bat" "%~dp0\RoughWizard.bat" >nul 2>&1
    )
)







